{
  "name": "@technic/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "start": "tsx src/server.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "build": "echo \"api: tsx runtime, no build\"",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:migrate:check": "tsx src/db/migrate.ts check",
    "db:migrate:status": "tsx src/db/migrate.ts status",
    "seed:admin": "tsx src/seed-admin.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "3.1091.0",
    "@aws-sdk/s3-request-presigner": "3.1091.0",
    "@fastify/cookie": "11.1.2",
    "@fastify/helmet": "13.1.0",
    "@fastify/rate-limit": "11.1.0",
    "@node-rs/argon2": "2.0.2",
    "@technic/contracts": "workspace:*",
    "drizzle-orm": "0.45.2",
    "fastify": "5.10.0",
    "fastify-plugin": "^5.0.1",
    "fastify-type-provider-zod": "7.0.0",
    "jose": "6.2.3",
    "pg": "8.22.0",
    "pino": "10.3.1",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@types/pg": "^8.11.0",
    "drizzle-kit": "0.31.10",
    "pino-pretty": "13.1.3",
    "tsx": "^4.20.0",
    "typescript": "6.0.3",
    "vitest": "4.1.10"
  }
}
