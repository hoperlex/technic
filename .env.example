# ─────────────────────────────────────────────────────────────
# Пример переменных окружения (этап 1).
# НЕ коммитить реальный .env. В проде секреты — в host env-файле
# /etc/technic-portal/prod.env (root:root, 0600), вне docker-образа.
# ─────────────────────────────────────────────────────────────

# ── App ──
NODE_ENV=production
API_PORT=3000
API_HOST=0.0.0.0
# Публичный origin портала (для CSRF/Origin-проверки и secure cookie)
PUBLIC_ORIGIN=https://portal.example.ru
LOG_LEVEL=info

# ── PostgreSQL (Yandex Managed) ──
# Runtime-пользователь без DDL-прав
DATABASE_URL=postgres://technic_runtime:CHANGE_ME@rc1a-xxxxxxxx.mdb.yandexcloud.net:6432/technic_portal?sslmode=verify-full
# Путь к Yandex root CA (монтируется read-only)
PGSSLROOTCERT=/etc/technic-portal/certs/yandex-root.crt
DB_POOL_MAX=10
# Migration-пользователь с DDL (используется ТОЛЬКО migrate-контейнером)
DATABASE_MIGRATION_URL=postgres://technic_migration:CHANGE_ME@rc1a-xxxxxxxx.mdb.yandexcloud.net:6432/technic_portal?sslmode=verify-full

# ── Auth ──
# Ed25519 ключи в PEM (SPKI/PKCS8). Приватный ключ — только у api-сервиса.
JWT_PRIVATE_KEY_PEM=
JWT_PUBLIC_KEY_PEM=
JWT_KID=technic-2026-01
JWT_ISSUER=technic-portal
JWT_AUDIENCE=technic-portal-web
ACCESS_TOKEN_TTL_SECONDS=900
REFRESH_TOKEN_TTL_SECONDS=1209600
# Секреты для подписи cookie и CSRF-токена (min 32 байта)
COOKIE_SECRET=CHANGE_ME_min_32_bytes_random
CSRF_SECRET=CHANGE_ME_min_32_bytes_random
# Argon2id (дефолты @node-rs/argon2 = OWASP-min)
ARGON_MEMORY_KIB=19456
ARGON_TIME_COST=2
ARGON_PARALLELISM=1

# ── cloud.ru Evolution Object Storage (S3) ──
S3_ENDPOINT=https://s3.cloud.ru
S3_REGION=ru-central-1
S3_BUCKET=technic-portal-files
# Access key format: <tenant_id>:<key_id>
S3_ACCESS_KEY_ID=TENANT_ID:KEY_ID
S3_SECRET_ACCESS_KEY=CHANGE_ME
# virtual-hosted-style (path-style отключён для новых бакетов с фев 2025)
S3_FORCE_PATH_STYLE=false
S3_UPLOAD_URL_TTL_SECONDS=600
S3_DOWNLOAD_URL_TTL_SECONDS=120

# ── Лимиты файлов ──
FILE_MAX_SIZE_BYTES=52428800
FILE_MAX_PER_REQUEST=20

# ── Mail (Yandex Postbox, опц. на этапе 1) ──
MAIL_ENABLED=false
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
MAIL_FROM=no-reply@example.ru

# ── Sentry (опц.) ──
SENTRY_DSN=

# ── Frontend (build-time) ──
VITE_API_BASE_URL=/api/v1
