# Пример vhost для EDGE-nginx на хосте (TLS termination, §23).
# Проксирует на контейнер web (127.0.0.1:8080). Файл кладётся в
# /etc/nginx/sites-available и не конфликтует с другими проектами на VPS.

server {
  listen 80;
  server_name auto.su10.ru;
  return 301 https://$host$request_uri;
}

server {
  listen 443 ssl;
  http2 on;
  server_name auto.su10.ru;

  ssl_certificate     /etc/letsencrypt/live/auto.su10.ru/fullchain.pem;
  ssl_certificate_key /etc/letsencrypt/live/auto.su10.ru/privkey.pem;

  client_max_body_size 2m;

  add_header Strict-Transport-Security "max-age=31536000; includeSubDomains" always;
  add_header X-Content-Type-Options nosniff always;
  add_header X-Frame-Options DENY always;
  add_header Referrer-Policy strict-origin-when-cross-origin always;
  # connect-src включает cloud.ru для presigned upload/download напрямую из браузера
  add_header Content-Security-Policy "default-src 'self'; img-src 'self' data:; style-src 'self' 'unsafe-inline'; font-src 'self' data:; script-src 'self'; connect-src 'self' https://s3.cloud.ru https://*.s3.cloud.ru" always;

  location / {
    proxy_pass http://127.0.0.1:8080;
    proxy_http_version 1.1;
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto https;
  }
}
